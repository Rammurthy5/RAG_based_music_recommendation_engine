# ==============================================================================
# Required API Keys
# ==============================================================================

# Anthropic API key for Claude LLM (used by rag-service for generation)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Genius API token (used by ingestion scripts to fetch lyrics)
GENIUS_ACCESS_TOKEN=your-genius-access-token-here

# MusicBrainz requires no API key — only a user-agent string (configured in code)

# ==============================================================================
# Optional Overrides (defaults are fine for local Docker Compose)
# ==============================================================================

# Weaviate connection (set by docker-compose, override for external Weaviate)
# WEAVIATE_HOST=weaviate
# WEAVIATE_HTTP_PORT=8080
# WEAVIATE_GRPC_PORT=50051

# RAG tuning
# TOP_K=10
# SIMILARITY_THRESHOLD=0.65
# LLM_TIMEOUT=15
# WEAVIATE_QUERY_TIMEOUT=5
# EMBEDDING_TIMEOUT=30

# Gateway settings
# RAG_SERVICE_URL=http://rag-service:8000
# PORT=8080
# RATE_LIMIT=20
# RATE_BURST=40
